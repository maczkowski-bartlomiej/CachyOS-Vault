#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=theme-build-lib
source "$SCRIPT_DIR/theme-build-lib"

init_theme_builder

OUTPUT_FILE="$THEME_OUTPUT_DIR/i3-theme.i3"

# -----------------------------------------------------------------------------
# i3 client color mapping
# -----------------------------------------------------------------------------
# i3 client color syntax:
#
#   client.focused          <border> <background> <text> <indicator> <child_border>
#   client.focused_inactive <border> <background> <text> <indicator> <child_border>
#   client.unfocused        <border> <background> <text> <indicator> <child_border>
#   client.urgent           <border> <background> <text> <indicator> <child_border>
#   client.placeholder      <border> <background> <text> <indicator> <child_border>
#   client.background       <background>
#
# Keep all client.* declarations in this generated include file.
# Do not use these variables later in ~/.config/i3/config.

FOCUSED_BORDER="$ACCENT"
FOCUSED_BG="$BG"
FOCUSED_TEXT="$FG"
FOCUSED_INDICATOR="$ACCENT"
FOCUSED_CHILD_BORDER="$ACCENT"

INACTIVE_BORDER="$BORDER"
INACTIVE_BG="$BG"
INACTIVE_TEXT="$FG_MUTED"
INACTIVE_INDICATOR="$BORDER"
INACTIVE_CHILD_BORDER="$BORDER"

UNFOCUSED_BORDER="$BORDER_SOFT"
UNFOCUSED_BG="$BG"
UNFOCUSED_TEXT="$FG_MUTED"
UNFOCUSED_INDICATOR="$BORDER_SOFT"
UNFOCUSED_CHILD_BORDER="$BORDER_SOFT"

URGENT_BORDER="$URGENT"
URGENT_BG="$URGENT"
URGENT_TEXT="$FG"
URGENT_INDICATOR="$URGENT"
URGENT_CHILD_BORDER="$URGENT"

PLACEHOLDER="$BLACK"
PLACEHOLDER_TEXT="$FG"

write_file_atomic "$OUTPUT_FILE" <<I3
# Generated by CachyOS-Vault. Do not edit directly.
# Source palette: custom-themes/color-palette/orchis-dark-palette.sh

# -----------------------------------------------------------------------------
# Palette variables
# -----------------------------------------------------------------------------
# These are kept for readability and future included snippets.
# Do not rely on these variables from the parent ~/.config/i3/config.

set \$bg                 $BG
set \$bg_alt             $BG_ALT
set \$surface            $SURFACE
set \$surface_2          $SURFACE_2
set \$surface_3          $SURFACE_3
set \$fg                 $FG
set \$fg_strong          $FG_STRONG
set \$fg_dim             $FG_DIM
set \$fg_muted           $FG_MUTED
set \$fg_disabled        $FG_DISABLED
set \$border             $BORDER
set \$border_soft        $BORDER_SOFT
set \$accent             $ACCENT
set \$accent_hover       $ACCENT_HOVER
set \$accent_active      $ACCENT_ACTIVE
set \$accent_dim         $ACCENT_DIM
set \$success            $SUCCESS
set \$warning            $WARNING
set \$error              $ERROR
set \$urgent             $URGENT
set \$primary            $PRIMARY
set \$secondary          $SECONDARY

# -----------------------------------------------------------------------------
# i3 client colors
# -----------------------------------------------------------------------------
# class                 border              background     text        indicator           child_border

client.focused          $FOCUSED_BORDER     $FOCUSED_BG     $FOCUSED_TEXT     $FOCUSED_INDICATOR    $FOCUSED_CHILD_BORDER
client.focused_inactive $INACTIVE_BORDER    $INACTIVE_BG    $INACTIVE_TEXT    $INACTIVE_INDICATOR   $INACTIVE_CHILD_BORDER
client.unfocused        $UNFOCUSED_BORDER   $UNFOCUSED_BG   $UNFOCUSED_TEXT   $UNFOCUSED_INDICATOR  $UNFOCUSED_CHILD_BORDER
client.urgent           $URGENT_BORDER      $URGENT_BG      $URGENT_TEXT      $URGENT_INDICATOR     $URGENT_CHILD_BORDER
client.placeholder      $PLACEHOLDER        $PLACEHOLDER    $PLACEHOLDER_TEXT  $PLACEHOLDER          $PLACEHOLDER
client.background       $BG


I3

log_ok "Generated $OUTPUT_FILE"
