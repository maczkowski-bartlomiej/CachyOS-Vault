#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=theme-build-lib
source "$SCRIPT_DIR/theme-build-lib"
init_theme_builder

OUTPUT_FILE="$THEME_OUTPUT_DIR/alacritty-theme.toml"
alacritty_bg="$BG"
alacritty_fg="$FG"
alacritty_cursor="$ACCENT"
alacritty_selection_bg="$ACCENT_DIM"
alacritty_selection_fg="$FG_STRONG"

write_file_atomic "$OUTPUT_FILE" <<TOML
# Generated by CachyOS-Vault. Do not edit directly.
# Source palette: custom-themes/color-palette/orchis-dark-palette.sh

[colors.primary]
background = "$alacritty_bg"
foreground = "$alacritty_fg"
dim_foreground = "$FG_MUTED"
bright_foreground = "$FG_STRONG"

[colors.cursor]
text = "$BG"
cursor = "$alacritty_cursor"

[colors.selection]
text = "$alacritty_selection_fg"
background = "$alacritty_selection_bg"

[colors.normal]
black = "$BLACK"
red = "$RED"
green = "$GREEN"
yellow = "$YELLOW"
blue = "$BLUE"
magenta = "$MAGENTA"
cyan = "$CYAN"
white = "$WHITE"

[colors.bright]
black = "$BLACK_BRIGHT"
red = "$RED_BRIGHT"
green = "$GREEN_BRIGHT"
yellow = "$YELLOW_BRIGHT"
blue = "$BLUE_BRIGHT"
magenta = "$MAGENTA_BRIGHT"
cyan = "$CYAN_BRIGHT"
white = "$WHITE_BRIGHT"
TOML
log_ok "Generated $OUTPUT_FILE"
