#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=theme-build-lib
source "$SCRIPT_DIR/theme-build-lib"

init_theme_builder

SOURCE_CONFIG="$REPO_ROOT/custom-configs/BetterLockScreen/betterlockscreenrc"
OUTPUT_FILE="$THEME_OUTPUT_DIR/betterlockscreenrc"

hex_body() {
    local color="${1#\#}"
    printf '%s' "${color^^}"
}

rgba() {
    local color="$1"
    local alpha="${2:-ff}"
    printf '%s%s' "$(hex_body "$color")" "$alpha"
}

require_file "$SOURCE_CONFIG"

write_file_atomic "$OUTPUT_FILE" < <(
    awk \
        -v solid_color="$(hex_body "$BG")" \
        -v loginbox="$(rgba "$BG" 00)" \
        -v loginshadow="$(rgba "$SHADOW" 00)" \
        -v font='"JetBrainsMono Nerd Font"' \
        -v ringcolor="$(rgba "$ACCENT")" \
        -v insidecolor="$(rgba "$SURFACE" aa)" \
        -v separatorcolor="$(rgba "$BORDER" 00)" \
        -v ringvercolor="$(rgba "$SUCCESS")" \
        -v insidevercolor="$(rgba "$SUCCESS" 22)" \
        -v ringwrongcolor="$(rgba "$ERROR")" \
        -v insidewrongcolor="$(rgba "$ERROR" 26)" \
        -v timecolor="$(rgba "$FG_STRONG")" \
        -v greetercolor="$(rgba "$FG" cc)" \
        -v layoutcolor="$(rgba "$FG_MUTED" cc)" \
        -v keyhlcolor="$(rgba "$ACCENT_ACTIVE")" \
        -v bshlcolor="$(rgba "$WARNING")" \
        -v verifcolor="$(rgba "$SUCCESS")" \
        -v wrongcolor="$(rgba "$ERROR")" \
        -v modifcolor="$(rgba "$WARNING")" \
        -v bgcolor="$(rgba "$BG")" \
        -v date_color="$(rgba "$FG_DIM" cc)" '
            BEGIN {
                values["solid_color"] = solid_color
                values["loginbox"] = loginbox
                values["loginshadow"] = loginshadow
                values["font"] = font
                values["ringcolor"] = ringcolor
                values["insidecolor"] = insidecolor
                values["separatorcolor"] = separatorcolor
                values["ringvercolor"] = ringvercolor
                values["insidevercolor"] = insidevercolor
                values["ringwrongcolor"] = ringwrongcolor
                values["insidewrongcolor"] = insidewrongcolor
                values["timecolor"] = timecolor
                values["greetercolor"] = greetercolor
                values["layoutcolor"] = layoutcolor
                values["keyhlcolor"] = keyhlcolor
                values["bshlcolor"] = bshlcolor
                values["verifcolor"] = verifcolor
                values["wrongcolor"] = wrongcolor
                values["modifcolor"] = modifcolor
                values["bgcolor"] = bgcolor
                args["--date-color"] = "--date-color=" date_color

                print "# Generated by CachyOS-Vault. Do not edit directly."
                print "# Source config: custom-configs/BetterLockScreen/betterlockscreenrc"
                print "# Source palette: custom-themes/color-palette/orchis-dark-palette.sh"
                print ""
            }
            {
                for (arg in args) {
                    if ($0 ~ "^[[:space:]]*" arg "=") {
                        print "  " args[arg]
                        next
                    }
                }
                for (key in values) {
                    if ($0 ~ "^[[:space:]]*" key "=") {
                        print key "=" values[key]
                        next
                    }
                }
                print
            }
        ' "$SOURCE_CONFIG"
)

log_ok "Generated $OUTPUT_FILE"
