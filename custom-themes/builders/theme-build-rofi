#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=theme-build-lib
source "$SCRIPT_DIR/theme-build-lib"
init_theme_builder

OUTPUT_FILE="$THEME_OUTPUT_DIR/rofi-theme.rasi"

rofi_bg="#1F1F1F"
rofi_bg_alt="#242424"
rofi_surface="#282828"
rofi_surface_2="#303030"
rofi_surface_3="#363636"
rofi_fg="#DCDCDC"
rofi_fg_strong="#F2F2F2"
rofi_fg_dim="#B0B0B0"
rofi_fg_muted="#7F8FA6"
rofi_fg_disabled="#5F6368"
rofi_border="#3A3A3A"
rofi_border_soft="#303030"
rofi_accent="$ACCENT_DIM"
rofi_accent_hover="$ACCENT"
rofi_accent_active="$ACCENT_HOVER"
rofi_accent_dim="#244A80"
rofi_selected_bg="#26394F"
rofi_selected_fg="$rofi_fg"

write_file_atomic "$OUTPUT_FILE" <<RASI
/* Generated by CachyOS-Vault. Do not edit directly. */
/* Source palette: custom-themes/color-palette/orchis-dark-palette.sh */

* {
    bg:                  $rofi_bg;
    bg-alt:              $rofi_bg_alt;
    surface:             $rofi_surface;
    surface-alt:         $rofi_surface_2;
    surface-strong:      $rofi_surface_3;

    fg:                  $rofi_fg;
    fg-strong:           $rofi_fg_strong;
    fg-dim:              $rofi_fg_dim;
    fg-muted:            $rofi_fg_muted;
    fg-disabled:         $rofi_fg_disabled;

    accent:              $rofi_accent;
    accent-hover:        $rofi_accent_hover;
    accent-active:       $rofi_accent_active;
    accent-soft:         $rofi_accent_dim;
    primary:             @accent;
    secondary:           $SECONDARY;

    urgent:              $ALERT;
    warning:             $WARNING;
    border:              $rofi_border;
    border-soft:         $rofi_border_soft;

    selected-bg:         $rofi_selected_bg;
    selected-fg:         $rofi_selected_fg;

    normal-bg:           @bg;
    normal-fg:           @fg;
    alternate-bg:        @surface;
    alternate-fg:        @fg;

    active-bg:           @surface-alt;
    active-fg:           @accent-hover;

    urgent-bg:           @surface-alt;
    urgent-fg:           @urgent;

    background:          @bg;
    background-alt:      @surface;
    foreground:          @fg;
    selected:            @selected-bg;
}
RASI

log_ok "Generated $OUTPUT_FILE"
