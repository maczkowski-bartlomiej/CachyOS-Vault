#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=theme-build-lib
source "$SCRIPT_DIR/theme-build-lib"

init_theme_builder

SOURCE_CONFIG="$REPO_ROOT/custom-configs/Ly/config.ini"
OUTPUT_FILE="$THEME_OUTPUT_DIR/ly-config.ini"

hex_body() {
    local color="${1#\#}"
    printf '%s' "${color^^}"
}

ly_color() {
    local style="$1"
    local color="$2"
    printf '0x%s%s' "$style" "$(hex_body "$color")"
}

require_file "$SOURCE_CONFIG"

write_file_atomic "$OUTPUT_FILE" < <(
    awk \
        -v allow_empty_password="false" \
        -v bg="$(ly_color 00 "$BG")" \
        -v border_fg="$(ly_color 00 "$ACCENT")" \
        -v error_bg="$(ly_color 00 "$BG")" \
        -v error_fg="$(ly_color 01 "$ERROR")" \
        -v fg="$(ly_color 00 "$FG")" \
        -v cmatrix_fg="$(ly_color 00 "$SECONDARY")" \
        -v cmatrix_head_col="$(ly_color 01 "$FG_STRONG")" \
        -v colormix_col1="$(ly_color 00 "$ACCENT")" \
        -v colormix_col2="$(ly_color 00 "$SECONDARY")" \
        -v colormix_col3="$(ly_color 00 "$SURFACE_3")" \
        -v doom_top_color="$(ly_color 00 "$ORANGE")" \
        -v doom_middle_color="$(ly_color 00 "$WARNING")" \
        -v doom_bottom_color="$(ly_color 00 "$FG_STRONG")" \
        -v gameoflife_fg="$(ly_color 00 "$SECONDARY")" '
            BEGIN {
                values["allow_empty_password"] = allow_empty_password
                values["bg"] = bg
                values["border_fg"] = border_fg
                values["error_bg"] = error_bg
                values["error_fg"] = error_fg
                values["fg"] = fg
                values["cmatrix_fg"] = cmatrix_fg
                values["cmatrix_head_col"] = cmatrix_head_col
                values["colormix_col1"] = colormix_col1
                values["colormix_col2"] = colormix_col2
                values["colormix_col3"] = colormix_col3
                values["doom_top_color"] = doom_top_color
                values["doom_middle_color"] = doom_middle_color
                values["doom_bottom_color"] = doom_bottom_color
                values["gameoflife_fg"] = gameoflife_fg

                print "# Generated by CachyOS-Vault. Do not edit directly."
                print "# Source config: custom-configs/Ly/config.ini"
                print "# Source palette: custom-themes/color-palette/orchis-dark-palette.sh"
                print ""
            }
            {
                for (key in values) {
                    if ($0 ~ "^[[:space:]]*" key "[[:space:]]*=") {
                        print key " = " values[key]
                        next
                    }
                }
                print
            }
        ' "$SOURCE_CONFIG"
)

log_ok "Generated $OUTPUT_FILE"
