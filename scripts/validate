#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=lib/vault-lib.sh
source "$REPO_ROOT/scripts/lib/vault-lib.sh"

failures=0

record_failure() {
    failures=$((failures + 1))
    log_error "$*"
}

run_check() {
    local label="$1"
    shift

    log_info "$label"
    if "$@"; then
        log_ok "$label"
    else
        record_failure "$label failed"
    fi
}

write_command_stub() {
    local path="${1:?path required}"
    local name="${2:?name required}"

    cat > "$path" <<STUB
#!/usr/bin/env bash
printf '$name' >> "\$VAULT_COMMAND_LOG"
printf ' %s' "\$@" >> "\$VAULT_COMMAND_LOG"
printf '\\n' >> "\$VAULT_COMMAND_LOG"
STUB
    chmod +x "$path"
}

check_shell_syntax() {
    local file

    while IFS= read -r -d '' file; do
        bash -n "$file"
    done < <(
        find "$REPO_ROOT" \
            -path "$REPO_ROOT/.git" -prune -o \
            -type f \
            \( -name '*.sh' -o -path '*/scripts/*' -o -path '*/builders/*' -o -path '*/installers/*' -o -path '*/bin/*' -o -path '*/custom-tweaks/*' \) \
            -print0
    )
}

check_zsh_config() {
    zsh -n "$REPO_ROOT/custom-configs/Zsh/.zshrc"
    jq -e . "$REPO_ROOT/custom-configs/Zsh/oh-my-posh/cachyos-compact.omp.json" >/dev/null
    ! rg -n 'p10k-instant|\.p10k|source .*powerlevel10k|cachyos-zsh-config' "$REPO_ROOT/custom-configs/Zsh"
}

check_theme_builder() {
    local tmp_home

    tmp_home="$(mktemp -d)"
    trap 'rm -rf "$tmp_home"' RETURN
    HOME="$tmp_home" "$REPO_ROOT/custom-configs/Themes/builders/theme-builder"

    test -f "$tmp_home/.config/custom-themes/i3-theme.i3"
    test -f "$tmp_home/.config/custom-themes/rofi-theme.rasi"
    test -f "$tmp_home/.config/custom-themes/polybar-theme.ini"
    test -f "$tmp_home/.config/custom-themes/dunst-theme.dunstrc"
    test -f "$tmp_home/.config/custom-themes/betterlockscreenrc"
    test -f "$tmp_home/.config/custom-themes/ly-config.ini"
    bash -n "$tmp_home/.config/custom-themes/betterlockscreenrc"
    test -f "$tmp_home/.config/custom-themes/alacritty-theme.toml"
    test -f "$tmp_home/.config/custom-themes/orchis-dark.micro"
    rg -q '^allow_empty_password = false$' "$tmp_home/.config/custom-themes/ly-config.ini"
    rg -q '^bigclock = en$' "$tmp_home/.config/custom-themes/ly-config.ini"
    rg -q '^box_title = PC Login$' "$tmp_home/.config/custom-themes/ly-config.ini"
    rg -q '^custom_sessions = /etc/ly/custom-sessions$' "$tmp_home/.config/custom-themes/ly-config.ini"
    rg -q '^hide_key_hints = true$' "$tmp_home/.config/custom-themes/ly-config.ini"
    rg -q '^initial_info_text = null$' "$tmp_home/.config/custom-themes/ly-config.ini"
    rg -q '^save = false$' "$tmp_home/.config/custom-themes/ly-config.ini"
    rg -q '^session_log = null$' "$tmp_home/.config/custom-themes/ly-config.ini"
    rg -q '^shell = false$' "$tmp_home/.config/custom-themes/ly-config.ini"
    rg -q '^waylandsessions = null$' "$tmp_home/.config/custom-themes/ly-config.ini"
    rg -q '^xinitrc = null$' "$tmp_home/.config/custom-themes/ly-config.ini"
    rg -q '^xsessions = /etc/ly/xsessions$' "$tmp_home/.config/custom-themes/ly-config.ini"

    rm -rf "$tmp_home"
    trap - RETURN
}

check_install_configs_dry_run() {
    local tmp_home

    tmp_home="$(mktemp -d)"
    trap 'rm -rf "$tmp_home"' RETURN
    HOME="$tmp_home" VAULT_SKIP_RELOAD=1 VAULT_SKIP_SYSTEM_CONFIGS=1 "$REPO_ROOT/installers/install-configs"

    test -f "$tmp_home/.config/i3/config"
    test -x "$tmp_home/.config/i3/scripts/mouse-warp"
    test -x "$tmp_home/.config/i3/scripts/picom-restart"
    test -x "$tmp_home/.config/i3/scripts/rofi-launcher"
    test -x "$tmp_home/.config/i3/scripts/screenshot-menu"
    test -x "$tmp_home/.config/i3/scripts/screenshot-current-monitor"
    test -x "$tmp_home/.config/i3/scripts/screenshot-lib"
    test -x "$tmp_home/.config/i3/scripts/volume-osd"
    test -x "$tmp_home/.config/i3/scripts/xob-listener"
    test -f "$tmp_home/.config/i3/wallpaper.jpg"
    test -f "$tmp_home/.config/rofi/config.rasi"
    test -f "$tmp_home/.config/redshift/redshift.conf"
    test -f "$tmp_home/.config/dunst/dunstrc"
    test -L "$tmp_home/.config/dunst/dunstrc.d/90-vault-theme.conf"
    test "$(readlink "$tmp_home/.config/dunst/dunstrc.d/90-vault-theme.conf")" = "$tmp_home/.config/custom-themes/dunst-theme.dunstrc"
    test -f "$tmp_home/.config/betterlockscreen/betterlockscreenrc"
    test -f "$tmp_home/.config/custom-themes/ly-config.ini"
    test -f "$REPO_ROOT/custom-configs/Ly/xsessions/i3.desktop"
    test -f "$tmp_home/.config/polybar/config.ini"
    test -x "$tmp_home/.config/polybar/launch.sh"
    test -x "$tmp_home/.config/polybar/scripts/polybar-script-lib.sh"
    test -x "$tmp_home/.config/polybar/scripts/audio-player.sh"
    test -f "$tmp_home/.config/alacritty/alacritty.toml"
    test -f "$tmp_home/.zshrc"
    test -f "$tmp_home/.config/oh-my-posh/cachyos-compact.omp.json"
    rg -n 'p10k-instant|\.p10k|source .*powerlevel10k|cachyos-zsh-config' "$tmp_home/.zshrc" && die "Installed .zshrc leaked p10k/instant-prompt references"
    test -f "$tmp_home/.config/env/session-env.sh"
    test -f "$tmp_home/.xprofile"
    test -e "$tmp_home/.config/environment.d/90-gaming.conf" && die "Stale gaming environment drop-in was installed"
    rg -q '^export QT_QPA_PLATFORMTHEME=qt6ct$' "$tmp_home/.config/env/session-env.sh"
    rg -q '^export QT_STYLE_OVERRIDE=kvantum$' "$tmp_home/.config/env/session-env.sh"
    rg -q '^export __GL_SHADER_DISK_CACHE=1$' "$tmp_home/.config/env/session-env.sh"
    rg -q '^export __GL_SHADER_DISK_CACHE_SIZE=12000000000$' "$tmp_home/.config/env/session-env.sh"
    rg -q '\.config/env/session-env\.sh' "$tmp_home/.xprofile"
    test -f "$tmp_home/.config/gtk-3.0/settings.ini"
    test -f "$tmp_home/.config/gtk-4.0/settings.ini"
    test -f "$tmp_home/.gtkrc-2.0"
    test -f "$tmp_home/.config/qt5ct/qt5ct.conf"
    test -f "$tmp_home/.config/qt6ct/qt6ct.conf"
    test -f "$tmp_home/.config/Kvantum/kvantum.kvconfig"
    rg -q '^gtk-font-name=Inter 11$' "$tmp_home/.config/gtk-3.0/settings.ini"
    rg -q '^gtk-font-name=Inter 11$' "$tmp_home/.config/gtk-4.0/settings.ini"
    rg -q '^gtk-font-name="Inter 11"$' "$tmp_home/.gtkrc-2.0"
    rg -q '^general="Inter,11,' "$tmp_home/.config/qt5ct/qt5ct.conf"
    rg -q '^general="Inter,11,' "$tmp_home/.config/qt6ct/qt6ct.conf"
    rg -q '^style=kvantum$' "$tmp_home/.config/qt5ct/qt5ct.conf"
    rg -q '^style=kvantum$' "$tmp_home/.config/qt6ct/qt6ct.conf"
    rg -q '^theme=Orchis-solidDark$' "$tmp_home/.config/Kvantum/kvantum.kvconfig"
    test -f "$tmp_home/.config/micro/settings.json"
    test -f "$tmp_home/.config/micro/colorschemes/orchis-dark.micro"
    test -f "$tmp_home/.config/picom/picom.conf"
    test -f "$tmp_home/.config/nwg-look/config"

    test -f "$tmp_home/.config/gtk-3.0/bookmarks" && die "install-configs must not install GTK bookmarks (tweak only)"
    test -x "$tmp_home/.local/bin/set-file-extensions" && die "install-configs must not install file-associations helper (tweak only)"
    test -f "$tmp_home/.icons/default/index.theme" && die "install-configs must not install cursor hardening (tweak only)"

    rm -rf "$tmp_home"
    trap - RETURN
}

check_i3_reload_restart() {
    local tmp_home tmp_bin log_file

    tmp_home="$(mktemp -d)"
    trap 'rm -rf "$tmp_home"' RETURN
    tmp_bin="$tmp_home/bin"
    log_file="$tmp_home/i3.log"
    install -d "$tmp_bin"
    : > "$log_file"

    write_command_stub "$tmp_bin/i3-msg" i3-msg

    PATH="$tmp_bin:$PATH" HOME="$tmp_home" REPO_ROOT="$REPO_ROOT" VAULT_COMMAND_LOG="$log_file" bash -c '
        set -euo pipefail
        source "$REPO_ROOT/installers/lib/install-lib.sh"
        reload_i3
    '

    test "$(sed -n '1p' "$log_file")" = "i3-msg reload"
    test "$(sed -n '2p' "$log_file")" = "i3-msg restart"

    rm -rf "$tmp_home"
    trap - RETURN
}

check_tweak_sources() {
    local src

    src="$REPO_ROOT/custom-tweaks/file-associations/set-file-extensions"
    require_file "$src"
    test -x "$src"
    rg -n '/home/lysy|nvim|thunar|archive-smart-extract' "$src" && die "set-file-extensions contains stale or hardcoded references"
    rg -q '^TEXT_DESKTOP=.*org\.gnome\.gedit\.desktop' "$src"
    rg -q '^FILES_DESKTOP=.*doublecmd\.desktop' "$src"
    rg -q '^ARCHIVE_DESKTOP=.*org\.gnome\.FileRoller\.desktop' "$src"

    src="$REPO_ROOT/custom-tweaks/gtk-bookmarks/bookmarks"
    require_file "$src"
    rg -q '^file:///mnt/dev Dev$' "$src"
    rg -q '^file:///mnt/dev-data Dev Data$' "$src"
    rg -q '^file:///mnt/data-hdd Data HDD$' "$src"

    src="$REPO_ROOT/custom-tweaks/drive-automounts/fstab-drive-automounts"
    require_file "$src"
    rg -q '^UUID=F85EFF175EFECCFE[[:space:]]+/mnt/dev[[:space:]]+ntfs3[[:space:]]' "$src"
    rg -q '^UUID=4EBE9588BE95696B[[:space:]]+/mnt/dev-data[[:space:]]+ntfs3[[:space:]]' "$src"
    rg -q '^UUID=16654759-f0f4-4933-bf8d-223be0319a42[[:space:]]+/mnt/data-hdd[[:space:]]+btrfs[[:space:]]' "$src"

    require_file "$REPO_ROOT/custom-tweaks/cursor-hardening/index.theme"
    require_file "$REPO_ROOT/custom-tweaks/cursor-hardening/.Xresources"
    require_file "$REPO_ROOT/custom-tweaks/system-units/enabled-units.txt"
    require_file "$REPO_ROOT/custom-tweaks/betterlockscreen-cache/wallpaper-path"
}

check_install_tweaks_picker() {
    local tmp_home tmp_bin log_file

    tmp_home="$(mktemp -d)"
    trap 'rm -rf "$tmp_home"' RETURN
    tmp_bin="$tmp_home/bin"
    log_file="$tmp_home/commands.log"
    install -d "$tmp_bin"
    : > "$log_file"

    cat > "$tmp_bin/xdg-mime" <<'STUB'
#!/usr/bin/env bash
printf 'xdg-mime %s\n' "$*" >> "$VAULT_COMMAND_LOG"
if [[ "${1:-}" == "default" ]]; then
    mkdir -p "$HOME/.config"
    printf '%s=%s\n' "${3:?mime required}" "${2:?desktop required}" >> "$HOME/.config/mimeapps.list"
fi
STUB

    cat > "$tmp_bin/gio" <<'STUB'
#!/usr/bin/env bash
printf 'gio %s\n' "$*" >> "$VAULT_COMMAND_LOG"
STUB

    cat > "$tmp_bin/findmnt" <<'STUB'
#!/usr/bin/env bash
printf 'findmnt %s\n' "$*" >> "$VAULT_COMMAND_LOG"
printf 'Success, no errors or warnings detected\n'
STUB

    cat > "$tmp_bin/systemctl" <<'STUB'
#!/usr/bin/env bash
printf 'systemctl %s\n' "$*" >> "$VAULT_COMMAND_LOG"
STUB

    cat > "$tmp_bin/xrdb" <<'STUB'
#!/usr/bin/env bash
printf 'xrdb %s\n' "$*" >> "$VAULT_COMMAND_LOG"
STUB

    cat > "$tmp_bin/betterlockscreen" <<'STUB'
#!/usr/bin/env bash
printf 'betterlockscreen %s\n' "$*" >> "$VAULT_COMMAND_LOG"
STUB

    cat > "$tmp_bin/update-desktop-database" <<'STUB'
#!/usr/bin/env bash
printf 'update-desktop-database %s\n' "$*" >> "$VAULT_COMMAND_LOG"
STUB

    cat > "$tmp_bin/sudo" <<'STUB'
#!/usr/bin/env bash
printf 'sudo %s\n' "$*" >> "$VAULT_COMMAND_LOG"
if [[ "${1:-}" == "systemctl" ]]; then
    "$@"
fi
STUB

    chmod +x "$tmp_bin"/*

    printf 'all\n' | PATH="$tmp_bin:$PATH" HOME="$tmp_home" VAULT_COMMAND_LOG="$log_file" \
        "$REPO_ROOT/installers/install-tweaks"

    test -x "$tmp_home/.local/bin/set-file-extensions"
    rg -q '^text/plain=org\.gnome\.gedit\.desktop' "$tmp_home/.config/mimeapps.list"
    rg -q '^application/json=org\.gnome\.gedit\.desktop' "$tmp_home/.config/mimeapps.list"
    rg -q '^inode/directory=doublecmd\.desktop' "$tmp_home/.config/mimeapps.list"
    rg -q '^application/zip=org\.gnome\.FileRoller\.desktop' "$tmp_home/.config/mimeapps.list"
    rg -q '^text/html=org\.gnome\.gedit\.desktop' "$tmp_home/.config/mimeapps.list" && die "text/html must not be mapped to the text editor"
    test -f "$tmp_home/.config/gtk-3.0/bookmarks"
    test -f "$tmp_home/.config/gtk-4.0/bookmarks"
    rg -q '^file:///mnt/dev Dev$' "$tmp_home/.config/gtk-3.0/bookmarks"
    test -f "$tmp_home/.icons/default/index.theme"
    test -f "$tmp_home/.Xresources"
    rg -q '^findmnt --verify --tab-file ' "$log_file"
    rg -q '^systemctl daemon-reload$' "$log_file"
    rg -q '^systemctl enable --now paccache\.timer$' "$log_file"
    rg -q "^xrdb -merge $tmp_home/\\.Xresources$" "$log_file"
    rg -q "^betterlockscreen -u $tmp_home/\\.config/i3/wallpaper\\.jpg$" "$log_file"

    : > "$log_file"
    printf '\n' | PATH="$tmp_bin:$PATH" HOME="$tmp_home" VAULT_COMMAND_LOG="$log_file" \
        "$REPO_ROOT/installers/install-tweaks"
    test -s "$log_file" && die "Canceling the tweak picker must not run commands"

    rm -rf "$tmp_home"
    trap - RETURN
}

check_package_manifests() {
    local file

    for file in "$REPO_ROOT"/custom-packages/*.txt; do
        LC_ALL=C sort -c "$file"
        rg -n '^[[:space:]]*$|[[:space:]]#' "$file" && die "Manifest has blank or inline-comment lines: $file"
    done

    rg -q '^alacritty$' "$REPO_ROOT/custom-packages/pacman-core-apps.txt"
    rg -q '^audacity$' "$REPO_ROOT/custom-packages/pacman-core-apps.txt"
    rg -q '^doublecmd-qt5$' "$REPO_ROOT/custom-packages/pacman-core-apps.txt"
    rg -q '^file-roller$' "$REPO_ROOT/custom-packages/pacman-core-apps.txt"
    rg -q '^gedit$' "$REPO_ROOT/custom-packages/pacman-core-apps.txt"
    rg -q '^mpv$' "$REPO_ROOT/custom-packages/pacman-core-apps.txt"
    rg -q '^btrfs-progs$' "$REPO_ROOT/custom-packages/pacman-core.txt"
    rg -q '^inter-font$' "$REPO_ROOT/custom-packages/pacman-core.txt"
    rg -q '^kvantum$' "$REPO_ROOT/custom-packages/pacman-core.txt"
    rg -q '^kvantum-qt5$' "$REPO_ROOT/custom-packages/pacman-core.txt"
    rg -q '^oh-my-zsh-git$' "$REPO_ROOT/custom-packages/pacman-core.txt"
    rg -q '^pacman-contrib$' "$REPO_ROOT/custom-packages/pacman-core.txt"
    rg -q '^qt5ct$' "$REPO_ROOT/custom-packages/pacman-core.txt"
    rg -q '^qt6ct$' "$REPO_ROOT/custom-packages/pacman-core.txt"
    rg -q '^xdg-utils$' "$REPO_ROOT/custom-packages/pacman-core.txt"
    rg -q '^zsh$' "$REPO_ROOT/custom-packages/pacman-core.txt"
    rg -q '^brave-origin-bin$' "$REPO_ROOT/custom-packages/pacman-extra-work.txt"
    rg -q '^betterlockscreen$' "$REPO_ROOT/custom-packages/aur.txt"
    rg -q '^oh-my-posh-bin$' "$REPO_ROOT/custom-packages/aur.txt"
    rg -q '^plasma6-themes-orchis-kde-git$' "$REPO_ROOT/custom-packages/aur.txt"
    rg -q '^com.github.marktext.marktext$' "$REPO_ROOT/custom-packages/flatpak.txt"
}

check_package_installer_picker() {
    local tmp_home tmp_bin log_file

    tmp_home="$(mktemp -d)"
    trap 'rm -rf "$tmp_home"' RETURN
    tmp_bin="$tmp_home/bin"
    log_file="$tmp_home/commands.log"
    install -d "$tmp_bin"
    : > "$log_file"

    write_command_stub "$tmp_bin/shelly" shelly
    write_command_stub "$tmp_bin/pacman" pacman
    write_command_stub "$tmp_bin/paru" paru

    cat > "$tmp_bin/sudo" <<'STUB'
#!/usr/bin/env bash
printf 'sudo %s\n' "$*" >> "$VAULT_COMMAND_LOG"
"$@"
STUB

    cat > "$tmp_bin/flatpak" <<'STUB'
#!/usr/bin/env bash
if [[ "${1:-}" == "remotes" ]]; then
    exit 0
fi
printf 'flatpak %s\n' "$*" >> "$VAULT_COMMAND_LOG"
STUB

    chmod +x "$tmp_bin"/*

    printf 'all\n' | PATH="$tmp_bin:$PATH" HOME="$tmp_home" VAULT_COMMAND_LOG="$log_file" \
        VAULT_PACKAGE_MANAGER=shelly "$REPO_ROOT/installers/install-packages"
    rg -q '^shelly install .*brightnessctl' "$log_file"
    rg -q '^shelly install .*bitwarden' "$log_file"
    rg -q '^shelly aur install .*betterlockscreen' "$log_file"
    rg -q '^flatpak remote-add --user --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo$' "$log_file"
    rg -q '^shelly flatpak install com.super_productivity.SuperProductivity --user -r flathub$' "$log_file"
    rg -q -- '--ui-mode' "$log_file" && die "Shelly install must not pass --ui-mode"

    : > "$log_file"
    printf 'all\n' | PATH="$tmp_bin:$PATH" HOME="$tmp_home" VAULT_COMMAND_LOG="$log_file" \
        VAULT_PACKAGE_MANAGER=legacy VAULT_AUR_HELPER=paru "$REPO_ROOT/installers/install-packages"
    rg -q '^pacman -S --needed .*brightnessctl' "$log_file"
    rg -q '^pacman -S --needed .*bitwarden' "$log_file"
    rg -q '^paru -S --needed .*betterlockscreen' "$log_file"
    rg -q '^flatpak install -y --user flathub .*com.github.marktext.marktext' "$log_file"

    : > "$log_file"
    printf '\n' | PATH="$tmp_bin:$PATH" HOME="$tmp_home" VAULT_COMMAND_LOG="$log_file" \
        VAULT_PACKAGE_MANAGER=shelly "$REPO_ROOT/installers/install-packages"
    test -s "$log_file" && die "Canceling the package picker must not run commands"

    rm -rf "$tmp_home"
    trap - RETURN
}

check_configure_themes() {
    local command tmp_home tmp_bin log_file tool_log_dir

    tmp_home="$(mktemp -d)"
    trap 'rm -rf "$tmp_home"' RETURN
    tmp_bin="$tmp_home/bin"
    log_file="$tmp_home/commands.log"
    tool_log_dir="$tmp_home/theme-logs"
    install -d "$tmp_bin"
    : > "$log_file"

    for command in nwg-look qt5ct qt6ct kvantummanager; do
        write_command_stub "$tmp_bin/$command" "$command"
    done

    printf '\n\n\n\n' | PATH="$tmp_bin:$PATH" HOME="$tmp_home" VAULT_COMMAND_LOG="$log_file" \
        VAULT_THEME_TOOL_LOG_DIR="$tool_log_dir" "$REPO_ROOT/installers/configure-themes"

    rg -q '^nwg-look$' "$log_file"
    rg -q '^qt5ct$' "$log_file"
    rg -q '^qt6ct$' "$log_file"
    rg -q '^kvantummanager$' "$log_file"
    test -f "$tool_log_dir/nwg-look.log"
    test -f "$tool_log_dir/qt5ct.log"
    test -f "$tool_log_dir/qt6ct.log"
    test -f "$tool_log_dir/kvantummanager.log"

    rm -rf "$tmp_home"
    trap - RETURN
}

check_stale_names() {
    test -d "$REPO_ROOT/packages" && die "Stale packages/ directory present"
    test -d "$REPO_ROOT/custom-themes" && die "Stale custom-themes/ directory present"
    find "$REPO_ROOT/custom-configs/Zsh" -name '.zcompdump*' -print | rg . && die "Stale .zcompdump files present in Zsh config"

    rg -n 'ytmusic\.sh|powermenu\.sh|polybar-theme\.sh' "$REPO_ROOT" \
        -g '!scripts/validate' \
        -g '!*.jpg' \
        -g '!*.png' && die "Stale script names still referenced in repo"
    rg -n 'screenshot-current-monito([^r]|$)' "$REPO_ROOT/custom-configs" "$REPO_ROOT/README.md" "$REPO_ROOT/docs" \
        -g '!*.jpg' \
        -g '!*.png' && die "Truncated screenshot-current-monitor reference found"
    rg -n 'Thunar|thunar|nvim-alacritty|archive-smart-extract|neovim' \
        "$REPO_ROOT/custom-configs" "$REPO_ROOT/custom-tweaks" "$REPO_ROOT/README.md" "$REPO_ROOT/docs" \
        "$REPO_ROOT/custom-packages" "$REPO_ROOT/scripts/lib" \
        -g '!*.jpg' \
        -g '!*.png' && die "Stale app references (thunar/nvim/etc.) found"
    ! rg -n 'install-all-with-nwg-look|installers/install-all([^a-zA-Z0-9_-]|$)|packages/core\.txt|packages/apps\.txt' \
        "$REPO_ROOT/README.md" "$REPO_ROOT/docs" "$REPO_ROOT/installers" "$REPO_ROOT/scripts/lib" \
        -g '!*.jpg' \
        -g '!*.png'
}

check_dunst_config() {
    local output tmp_home

    if ! command_exists dunst; then
        log_warn "dunst not found; skipped config parse"
        return 0
    fi

    tmp_home="$(mktemp -d)"
    trap 'rm -rf "$tmp_home"' RETURN

    HOME="$tmp_home" "$REPO_ROOT/custom-configs/Themes/builders/theme-build-dunst"
    install -d "$tmp_home/.config/dunst/dunstrc.d"
    ln -s "$tmp_home/.config/custom-themes/dunst-theme.dunstrc" "$tmp_home/.config/dunst/dunstrc.d/90-vault-theme.conf"

    output="$(HOME="$tmp_home" dunst -conf "$REPO_ROOT/custom-configs/Dunst/dunstrc" -verbosity warn -print 2>&1 || true)"
    output="$(printf '%s\n' "$output" | rg -v 'Cannot open X11 display|Couldn'\''t initialize X11 output|Aborting\\.\\.\\.' || true)"
    [ -z "$output" ]

    rm -rf "$tmp_home"
    trap - RETURN
}

check_polybar_smoke() {
    "$REPO_ROOT/custom-configs/Polybar/scripts/audio-output.sh" print >/dev/null
    "$REPO_ROOT/custom-configs/Polybar/scripts/screen-record.sh" status >/dev/null
    "$REPO_ROOT/custom-configs/Polybar/scripts/notification-history.sh" print >/dev/null
}

check_registry() {
    local builder group tweak

    # shellcheck source=lib/vault-registry.sh
    source "$REPO_ROOT/scripts/lib/vault-registry.sh"

    for builder in "${VAULT_THEME_BUILDERS[@]}"; do
        test -x "$REPO_ROOT/custom-configs/Themes/builders/$builder"
        rg -q "$builder" "$REPO_ROOT/docs"
    done

    for group in "${VAULT_CONFIG_GROUPS[@]}"; do
        rg -q "$group" "$REPO_ROOT/installers/lib/install-lib.sh"
    done

    for tweak in "${VAULT_TWEAKS[@]}"; do
        rg -q "$tweak" "$REPO_ROOT/installers/install-tweaks" "$REPO_ROOT/installers/lib/install-lib.sh"
    done
}

check_shellcheck_if_available() {
    if ! command_exists shellcheck; then
        log_warn "shellcheck not found; skipped"
        return 0
    fi

    shellcheck -x -e SC1091 \
        "$REPO_ROOT"/scripts/validate \
        "$REPO_ROOT"/scripts/lib/*.sh \
        "$REPO_ROOT"/installers/install-* \
        "$REPO_ROOT"/installers/configure-themes \
        "$REPO_ROOT"/installers/lib/*.sh \
        "$REPO_ROOT"/custom-configs/Themes/builders/theme-build* \
        "$REPO_ROOT"/custom-configs/Polybar/scripts/*.sh \
        "$REPO_ROOT"/custom-configs/I3/scripts/* \
        "$REPO_ROOT"/custom-tweaks/file-associations/set-file-extensions \
        "$REPO_ROOT"/custom-tweaks/cursor-hardening/Xresources-merge.sh
}

cd "$REPO_ROOT"

run_check "Shell syntax" check_shell_syntax
run_check "Zsh config" check_zsh_config
run_check "Theme builder dry run" check_theme_builder
run_check "install-configs dry run" check_install_configs_dry_run
run_check "i3 reload/restart routing" check_i3_reload_restart
run_check "Tweak sources" check_tweak_sources
run_check "install-tweaks picker routing" check_install_tweaks_picker
run_check "Package manifests" check_package_manifests
run_check "install-packages picker routing" check_package_installer_picker
run_check "configure-themes routing" check_configure_themes
run_check "Stale-name scan" check_stale_names
run_check "Dunst config parse" check_dunst_config
run_check "Polybar smoke tests" check_polybar_smoke
run_check "Registry consistency" check_registry
run_check "ShellCheck optional pass" check_shellcheck_if_available

if [ "$failures" -gt 0 ]; then
    die "$failures validation check(s) failed"
fi

log_ok "All validation checks passed"
