#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
PACKAGE_SOURCE_DIR="$REPO_ROOT/custom-packages"

# shellcheck source=../scripts/lib/vault-lib.sh
source "$REPO_ROOT/scripts/lib/vault-lib.sh"

MANIFEST_PACKAGES=()
PACKAGE_MANIFESTS=()
SELECTED_MANIFESTS=()
FLATPAK_SCOPE_ARGS=()
SHELLY_FLATPAK_SCOPE_ARGS=()

usage() {
    cat <<'USAGE'
Usage: installers/install-packages

Shows a numbered picker for package manifests under custom-packages/.

Picker input:
  blank       cancel
  all         install every listed manifest
  1 3 5       install selected manifest numbers

Environment:
  VAULT_PACKAGE_MANAGER=auto|shelly|legacy
  VAULT_AUR_HELPER=paru|yay
  VAULT_SKIP_AUR=1
  VAULT_SKIP_FLATPAK=1
  VAULT_FLATPAK_REMOTE=flathub
  VAULT_FLATPAK_REMOTE_URL=https://dl.flathub.org/repo/flathub.flatpakrepo
  VAULT_FLATPAK_SCOPE=user|system|none|auto
USAGE
}

read_manifest() {
    local manifest="${1:?manifest required}"
    local package

    require_file "$manifest"
    MANIFEST_PACKAGES=()

    while IFS= read -r package || [[ -n "$package" ]]; do
        [[ -n "$package" ]] || continue
        [[ "$package" != \#* ]] || continue
        [[ "$package" != *[[:space:]]* ]] || die "Manifest entries must not contain whitespace: $manifest: $package"
        MANIFEST_PACKAGES+=("$package")
    done < "$manifest"
}

run_as_root() {
    if ((EUID == 0)); then
        "$@"
    elif command_exists sudo; then
        sudo "$@"
    else
        die "sudo is required to run: $*"
    fi
}

resolve_package_manager() {
    local requested="${1:?manager required}"

    case "$requested" in
        auto)
            if command_exists shelly; then
                printf '%s\n' shelly
            else
                log_warn "Shelly not found; using legacy package installers"
                printf '%s\n' legacy
            fi
            ;;
        shelly)
            command_exists shelly || die "shelly is required for VAULT_PACKAGE_MANAGER=shelly"
            printf '%s\n' shelly
            ;;
        legacy)
            printf '%s\n' legacy
            ;;
        *)
            die "VAULT_PACKAGE_MANAGER must be auto, shelly, or legacy"
            ;;
    esac
}

manifest_label() {
    local manifest="${1:?manifest required}"
    basename -- "$manifest" .txt
}

load_package_manifests() {
    local manifest

    PACKAGE_MANIFESTS=()
    if [[ -f "$PACKAGE_SOURCE_DIR/pacman-core.txt" ]]; then
        PACKAGE_MANIFESTS+=("$PACKAGE_SOURCE_DIR/pacman-core.txt")
    fi

    if [[ -f "$PACKAGE_SOURCE_DIR/pacman-core-apps.txt" ]]; then
        PACKAGE_MANIFESTS+=("$PACKAGE_SOURCE_DIR/pacman-core-apps.txt")
    fi

    while IFS= read -r -d '' manifest; do
        PACKAGE_MANIFESTS+=("$manifest")
    done < <(
        find "$PACKAGE_SOURCE_DIR" -maxdepth 1 -type f -name 'pacman-*.txt' \
            ! -name 'pacman-core.txt' ! -name 'pacman-core-apps.txt' -print0 | LC_ALL=C sort -z
    )

    if [[ -f "$PACKAGE_SOURCE_DIR/aur.txt" ]]; then
        PACKAGE_MANIFESTS+=("$PACKAGE_SOURCE_DIR/aur.txt")
    fi

    if [[ -f "$PACKAGE_SOURCE_DIR/flatpak.txt" ]]; then
        PACKAGE_MANIFESTS+=("$PACKAGE_SOURCE_DIR/flatpak.txt")
    fi

    while IFS= read -r -d '' manifest; do
        PACKAGE_MANIFESTS+=("$manifest")
    done < <(
        find "$PACKAGE_SOURCE_DIR" -maxdepth 1 -type f -name '*.txt' \
            ! -name 'pacman-*.txt' ! -name 'aur.txt' ! -name 'flatpak.txt' -print0 | LC_ALL=C sort -z
    )

    ((${#PACKAGE_MANIFESTS[@]} > 0)) || die "No package manifests found in custom-packages"
}

print_package_menu() {
    local index manifest

    log_info "Package manifests"
    for index in "${!PACKAGE_MANIFESTS[@]}"; do
        manifest="${PACKAGE_MANIFESTS[$index]}"
        printf '%2d) %s\n' "$((index + 1))" "$(manifest_label "$manifest")"
    done
    printf 'Selection [blank cancels, all installs every manifest]: '
}

select_package_manifests() {
    local input token normalized index manifest
    declare -A seen=()

    print_package_menu
    IFS= read -r input || input=""
    normalized="${input//,/ }"

    if [[ -z "$normalized" ]]; then
        log_info "Package installation canceled"
        exit 0
    fi

    if [[ "$normalized" == "all" ]]; then
        SELECTED_MANIFESTS=("${PACKAGE_MANIFESTS[@]}")
        return 0
    fi

    SELECTED_MANIFESTS=()
    for token in $normalized; do
        [[ "$token" =~ ^[0-9]+$ ]] || die "Invalid selection: $token"
        index=$((token - 1))
        ((index >= 0 && index < ${#PACKAGE_MANIFESTS[@]})) || die "Selection out of range: $token"
        manifest="${PACKAGE_MANIFESTS[$index]}"
        if [[ -z "${seen[$manifest]:-}" ]]; then
            SELECTED_MANIFESTS+=("$manifest")
            seen[$manifest]=1
        fi
    done

    ((${#SELECTED_MANIFESTS[@]} > 0)) || die "No package manifests selected"
}

install_shelly_manifest() {
    local label="${1:?label required}"
    local manifest="${2:?manifest required}"

    read_manifest "$manifest"
    if ((${#MANIFEST_PACKAGES[@]} == 0)); then
        log_warn "No $label packages listed in ${manifest#"$REPO_ROOT"/}"
        return 0
    fi

    log_info "Installing $label packages from ${manifest#"$REPO_ROOT"/} with Shelly"
    shelly install "${MANIFEST_PACKAGES[@]}"
}

install_pacman_manifest() {
    local label="${1:?label required}"
    local manifest="${2:?manifest required}"

    read_manifest "$manifest"
    if ((${#MANIFEST_PACKAGES[@]} == 0)); then
        log_warn "No $label packages listed in ${manifest#"$REPO_ROOT"/}"
        return 0
    fi

    log_info "Installing $label packages from ${manifest#"$REPO_ROOT"/}"
    run_as_root pacman -S --needed "${MANIFEST_PACKAGES[@]}"
}

install_arch_manifest() {
    local label="${1:?label required}"
    local manifest="${2:?manifest required}"

    if [[ "$PACKAGE_MANAGER" == "shelly" ]]; then
        install_shelly_manifest "$label" "$manifest"
    else
        install_pacman_manifest "$label" "$manifest"
    fi
}

detect_aur_helper() {
    if [[ -n "${VAULT_AUR_HELPER:-}" ]]; then
        command_exists "$VAULT_AUR_HELPER" || die "AUR helper not found: $VAULT_AUR_HELPER"
        printf '%s\n' "$VAULT_AUR_HELPER"
    elif command_exists paru; then
        printf '%s\n' paru
    elif command_exists yay; then
        printf '%s\n' yay
    else
        die "No AUR helper found. Install paru/yay or set VAULT_AUR_HELPER."
    fi
}

install_aur_manifest() {
    local manifest="${1:?manifest required}"
    local helper

    if [[ -n "${VAULT_SKIP_AUR:-}" ]]; then
        log_info "Skipped AUR packages because VAULT_SKIP_AUR is set"
        return 0
    fi

    read_manifest "$manifest"
    if ((${#MANIFEST_PACKAGES[@]} == 0)); then
        log_warn "No AUR packages listed in ${manifest#"$REPO_ROOT"/}"
        return 0
    fi

    helper="$(detect_aur_helper)"
    log_info "Installing AUR packages from ${manifest#"$REPO_ROOT"/} with $helper"
    "$helper" -S --needed "${MANIFEST_PACKAGES[@]}"
}

install_shelly_aur_manifest() {
    local manifest="${1:?manifest required}"

    if [[ -n "${VAULT_SKIP_AUR:-}" ]]; then
        log_info "Skipped AUR packages because VAULT_SKIP_AUR is set"
        return 0
    fi

    read_manifest "$manifest"
    if ((${#MANIFEST_PACKAGES[@]} == 0)); then
        log_warn "No AUR packages listed in ${manifest#"$REPO_ROOT"/}"
        return 0
    fi

    log_info "Installing AUR packages from ${manifest#"$REPO_ROOT"/} with Shelly"
    shelly aur install "${MANIFEST_PACKAGES[@]}"
}

install_aur_packages() {
    local manifest="${1:?manifest required}"

    if [[ "$PACKAGE_MANAGER" == "shelly" ]]; then
        install_shelly_aur_manifest "$manifest"
    else
        install_aur_manifest "$manifest"
    fi
}

flatpak_remote_exists() {
    local scope="${1:?scope required}"
    local remote="${2:?remote required}"
    local name

    while IFS= read -r name; do
        [[ "$name" == "$remote" ]] && return 0
    done < <(flatpak remotes "--$scope" --columns=name 2>/dev/null || true)

    return 1
}

ensure_flatpak_user_remote() {
    local remote="${1:?remote required}"
    local remote_url="${VAULT_FLATPAK_REMOTE_URL:-https://dl.flathub.org/repo/flathub.flatpakrepo}"

    if flatpak_remote_exists user "$remote"; then
        return 0
    fi

    log_info "Adding Flatpak user remote $remote"
    flatpak remote-add --user --if-not-exists "$remote" "$remote_url"
}

resolve_flatpak_scope_args() {
    local remote="${1:?remote required}"
    local scope="${VAULT_FLATPAK_SCOPE:-user}"

    case "$scope" in
        auto)
            if flatpak_remote_exists user "$remote"; then
                FLATPAK_SCOPE_ARGS=(--user)
                SHELLY_FLATPAK_SCOPE_ARGS=(--user)
            elif flatpak_remote_exists system "$remote"; then
                FLATPAK_SCOPE_ARGS=(--system)
                SHELLY_FLATPAK_SCOPE_ARGS=()
            else
                die "Flatpak remote not found: $remote. Add it or set VAULT_FLATPAK_REMOTE."
            fi
            ;;
        user)
            ensure_flatpak_user_remote "$remote"
            FLATPAK_SCOPE_ARGS=(--user)
            SHELLY_FLATPAK_SCOPE_ARGS=(--user)
            ;;
        system)
            flatpak_remote_exists system "$remote" || die "Flatpak system remote not found: $remote"
            FLATPAK_SCOPE_ARGS=(--system)
            SHELLY_FLATPAK_SCOPE_ARGS=()
            ;;
        none|"")
            FLATPAK_SCOPE_ARGS=()
            SHELLY_FLATPAK_SCOPE_ARGS=()
            ;;
        *) die "VAULT_FLATPAK_SCOPE must be user, system, none, or auto" ;;
    esac
}

install_flatpak_manifest() {
    local manifest="${1:?manifest required}"
    local remote="${VAULT_FLATPAK_REMOTE:-flathub}"

    if [[ -n "${VAULT_SKIP_FLATPAK:-}" ]]; then
        log_info "Skipped Flatpak packages because VAULT_SKIP_FLATPAK is set"
        return 0
    fi

    command_exists flatpak || die "flatpak is required to install ${manifest#"$REPO_ROOT"/}"

    read_manifest "$manifest"
    if ((${#MANIFEST_PACKAGES[@]} == 0)); then
        log_warn "No Flatpak packages listed in ${manifest#"$REPO_ROOT"/}"
        return 0
    fi

    resolve_flatpak_scope_args "$remote"

    log_info "Installing Flatpak packages from ${manifest#"$REPO_ROOT"/}"
    flatpak install -y "${FLATPAK_SCOPE_ARGS[@]}" "$remote" "${MANIFEST_PACKAGES[@]}"
}

install_shelly_flatpak_manifest() {
    local manifest="${1:?manifest required}"
    local remote="${VAULT_FLATPAK_REMOTE:-flathub}"
    local package

    if [[ -n "${VAULT_SKIP_FLATPAK:-}" ]]; then
        log_info "Skipped Flatpak packages because VAULT_SKIP_FLATPAK is set"
        return 0
    fi

    command_exists flatpak || die "flatpak is required to install ${manifest#"$REPO_ROOT"/}"

    read_manifest "$manifest"
    if ((${#MANIFEST_PACKAGES[@]} == 0)); then
        log_warn "No Flatpak packages listed in ${manifest#"$REPO_ROOT"/}"
        return 0
    fi

    resolve_flatpak_scope_args "$remote"

    log_info "Installing Flatpak packages from ${manifest#"$REPO_ROOT"/} with Shelly"
    for package in "${MANIFEST_PACKAGES[@]}"; do
        shelly flatpak install "$package" "${SHELLY_FLATPAK_SCOPE_ARGS[@]}" -r "$remote"
    done
}

install_flatpak_packages() {
    local manifest="${1:?manifest required}"

    if [[ "$PACKAGE_MANAGER" == "shelly" ]]; then
        install_shelly_flatpak_manifest "$manifest"
    else
        install_flatpak_manifest "$manifest"
    fi
}

install_manifest() {
    local manifest="${1:?manifest required}"
    local label

    label="$(manifest_label "$manifest")"
    case "$label" in
        aur) install_aur_packages "$manifest" ;;
        flatpak) install_flatpak_packages "$manifest" ;;
        *) install_arch_manifest "$label" "$manifest" ;;
    esac
}

if (($# > 0)); then
    case "${1:-}" in
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage >&2
            die "install-packages uses the interactive picker; set VAULT_PACKAGE_MANAGER in the environment for manager mode"
            ;;
    esac
fi

load_package_manifests
select_package_manifests

PACKAGE_MANAGER="$(resolve_package_manager "${VAULT_PACKAGE_MANAGER:-auto}")"

for manifest in "${SELECTED_MANIFESTS[@]}"; do
    install_manifest "$manifest"
done
