#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/install-lib.sh
source "$SCRIPT_DIR/lib/install-lib.sh"

print_menu() {
    local i

    printf 'Available configs:\n'
    for i in "${!VAULT_CONFIG_GROUPS[@]}"; do
        printf '  %d) %s\n' "$((i + 1))" "${VAULT_CONFIG_GROUPS[$i]}"
    done
    printf '  all) all configs\n'
    printf '  q) quit\n\n'
    printf 'Enter numbers separated by spaces:\n'
}

selection_to_group() {
    local selection="$1"

    if [[ "$selection" =~ ^[0-9]+$ ]] &&
        ((selection >= 1 && selection <= ${#VAULT_CONFIG_GROUPS[@]})); then
        printf '%s\n' "${VAULT_CONFIG_GROUPS[$((selection - 1))]}"
        return 0
    fi

    return 1
}

print_menu
read -r -a selections

if [[ "${#selections[@]}" -eq 0 ]]; then
    die "No selection provided"
fi

for selection in "${selections[@]}"; do
    case "$selection" in
        q|Q)
            log_info "Quit"
            exit 0
            ;;
    esac
done

run_theme_builders

for selection in "${selections[@]}"; do
    case "$selection" in
        all)
            install_all_configs
            run_nwg_look
            exit 0
            ;;
        *)
            if group="$(selection_to_group "$selection")"; then
                install_app_config "$group"
            else
                die "Unknown selection: $selection"
            fi
            ;;
    esac
done

log_ok "Installed selected config groups"
