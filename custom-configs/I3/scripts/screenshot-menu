#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=screenshot-lib
source "$SCRIPT_DIR/screenshot-lib"

require_screenshot_commands maim xclip rofi xdotool xrandr

FILE="$(new_screenshot_file)"
CHOICE="$(printf "Area\nWindow\nFull screen\n" | rofi -dmenu -p "Screenshot")"

# Wait for rofi/picom fade-out so the menu is not captured.
sleep 0.4

case "$CHOICE" in
    "Area")
        maim -u -s "$FILE"
        ;;
    "Window")
        WINDOW_ID="$(xdotool selectwindow)"
        maim -u -i "$WINDOW_ID" "$FILE"
        ;;
    "Full screen")
        GEOM="$(current_monitor_geometry)"
        maim -u -g "$GEOM" "$FILE"
        ;;
    *)
        exit 0
        ;;
esac

copy_image_to_clipboard "$FILE"
notify_screenshot_done "$FILE"
