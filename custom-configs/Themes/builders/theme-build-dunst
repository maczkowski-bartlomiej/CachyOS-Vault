#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=theme-build-lib
source "$SCRIPT_DIR/theme-build-lib"
init_theme_builder

OUTPUT_FILE="$THEME_OUTPUT_DIR/dunst-theme.dunstrc"

dunst_bg="$BG"
dunst_bg_low="$SURFACE"
dunst_bg_critical="$SURFACE_3"
dunst_fg="$FG"
dunst_fg_low="$FG_MUTED"
dunst_fg_critical="$FG_STRONG"
dunst_frame="$BORDER"
dunst_frame_low="$BORDER_SOFT"
dunst_frame_critical="$ALERT"

write_file_atomic "$OUTPUT_FILE" <<DUNSTRC
# Generated by CachyOS-Vault. Do not edit directly.
# Source palette: custom-configs/Themes/color-palette/orchis-dark-palette.sh

[global]
    frame_color = "$dunst_frame"
    separator_color = frame

[urgency_low]
    background = "$dunst_bg_low"
    foreground = "$dunst_fg_low"
    frame_color = "$dunst_frame_low"
    highlight = "$PRIMARY"

[urgency_normal]
    background = "$dunst_bg"
    foreground = "$dunst_fg"
    frame_color = "$PRIMARY"
    highlight = "$PRIMARY"

[urgency_critical]
    background = "$dunst_bg_critical"
    foreground = "$dunst_fg_critical"
    frame_color = "$dunst_frame_critical"
    highlight = "$dunst_frame_critical"
DUNSTRC

log_ok "Generated $OUTPUT_FILE"
