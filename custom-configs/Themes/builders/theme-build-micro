#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=theme-build-lib
source "$SCRIPT_DIR/theme-build-lib"
init_theme_builder

OUTPUT_FILE="$THEME_OUTPUT_DIR/orchis-dark.micro"

micro_bg="$BG"
micro_fg="$FG"
micro_cursor_line_bg="#252525"
micro_selection_bg="#333333"
micro_selection_fg="#DCDCDC"
micro_status_bg="#2A2A2A"
micro_tab_bg="#242424"
micro_tab_active_bg="#303030"
micro_foreground_alt="#7F8FA6"

write_file_atomic "$OUTPUT_FILE" <<EOF
# Generated by CachyOS-Vault. Do not edit directly.
# Source palette: custom-configs/Themes/color-palette/orchis-dark-palette.sh

color-link default "$micro_fg,$micro_bg"

# UI
color-link selection "$micro_selection_fg,$micro_selection_bg"
color-link cursor-line ",$micro_cursor_line_bg"
color-link current-line-number "$SECONDARY,$micro_cursor_line_bg"
color-link line-number "$micro_foreground_alt,$micro_bg"
color-link color-column ",#262626"

color-link statusline "$FG,$micro_status_bg"
color-link statusline.inactive "$FG_MUTED,#242424"
color-link statusline.suggestions "$FG,#303030"

color-link tabbar "$FG_MUTED,$micro_tab_bg"
color-link tabbar.active "$FG,$micro_tab_active_bg"

color-link indent-char "$FG_MUTED"
color-link scrollbar "$FG_MUTED,$SURFACE"
color-link divider "$SURFACE_3"

color-link message "$FG,$BG"
color-link error-message "$ERROR,$BG"

color-link hlsearch "$BG,#B08A2E"
color-link match-brace "$FG,#3A3A3A"

# Syntax
color-link comment "$FG_MUTED"
color-link comment.bright "$micro_foreground_alt"

color-link identifier "$FG"
color-link identifier.class "$PRIMARY"
color-link identifier.var "$FG"

color-link constant "$WARNING"
color-link constant.number "$WARNING"
color-link constant.string "$SUCCESS"
color-link constant.string.url "$PRIMARY"

color-link statement "$PRIMARY"
color-link symbol "$FG_DIM"
color-link symbol.brackets "$FG_DIM"
color-link symbol.operator "$FG_DIM"

color-link preproc "$SECONDARY"
color-link type "$PRIMARY"
color-link type.keyword "$PRIMARY"
color-link special "$SECONDARY"
color-link underlined "$PRIMARY"

color-link error "$ERROR"
color-link todo "$WARNING,$BG_ALT"

color-link diff-added "$SUCCESS"
color-link diff-modified "$WARNING"
color-link diff-deleted "$ERROR"

color-link gutter-info "$PRIMARY"
color-link gutter-warning "$WARNING"
color-link gutter-error "$ERROR"

color-link tab-error "$ERROR"
color-link trailingws ",#3A2222"
EOF

log_ok "Generated $OUTPUT_FILE"
