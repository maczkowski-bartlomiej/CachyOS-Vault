#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=theme-build-lib
source "$SCRIPT_DIR/theme-build-lib"
init_theme_builder

OUTPUT_FILE="$THEME_OUTPUT_DIR/polybar-theme.ini"

workspace_focused="$LIME"
workspace_visible="#7F8FA6"
workspace_unfocused="#7F8FA6"
workspace_urgent="$ALERT"

write_file_atomic "$OUTPUT_FILE" <<INI
# Generated by CachyOS-Vault. Do not edit directly.
# Source palette: custom-configs/Themes/color-palette/orchis-dark-palette.sh

[colors]
background = $BG
background-alt = $BG_ALT
surface = $SURFACE
surface-alt = $SURFACE_3

foreground = $FG
foreground-strong = $FG_STRONG
foreground-dim = $FG_DIM
foreground-muted = $FG_MUTED
foreground-alt = $workspace_unfocused

primary = $PRIMARY
secondary = $SECONDARY
accent = $ACCENT

alert = $ALERT
error = $ERROR
warning = $WARNING
success = $SUCCESS

border = $BORDER

workspace-focused = $workspace_focused
workspace-visible = $workspace_visible
workspace-unfocused = $workspace_unfocused
workspace-urgent = $workspace_urgent
INI

log_ok "Generated $OUTPUT_FILE"
