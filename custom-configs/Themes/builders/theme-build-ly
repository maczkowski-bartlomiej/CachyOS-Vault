#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=theme-build-lib
source "$SCRIPT_DIR/theme-build-lib"

init_theme_builder

SOURCE_CONFIG="$REPO_ROOT/custom-configs/Ly/config.ini"
OUTPUT_FILE="$THEME_OUTPUT_DIR/ly-config.ini"

hex_body() {
    local color="${1#\#}"
    printf '%s' "${color^^}"
}

ly_color() {
    local style="$1"
    local color="$2"
    printf '0x%s%s' "$style" "$(hex_body "$color")"
}

require_file "$SOURCE_CONFIG"

write_file_atomic "$OUTPUT_FILE" < <(
    awk \
        -v allow_empty_password="false" \
        -v animation="none" \
        -v asterisk="*" \
        -v bg="$(ly_color 00 "$BG")" \
        -v bigclock="en" \
        -v blank_box="true" \
        -v border_fg="$(ly_color 00 "$ACCENT")" \
        -v box_title="PC Login" \
        -v clear_password="false" \
        -v clock="null" \
        -v custom_sessions="/etc/ly/custom-sessions" \
        -v default_input="login" \
        -v error_bg="$(ly_color 00 "$BG")" \
        -v error_fg="$(ly_color 01 "$ERROR")" \
        -v fg="$(ly_color 00 "$FG")" \
        -v hide_key_hints="true" \
        -v hide_keyboard_locks="true" \
        -v hide_version_string="true" \
        -v initial_info_text="null" \
        -v input_len="34" \
        -v margin_box_h="2" \
        -v margin_box_v="1" \
        -v save="false" \
        -v session_log="null" \
        -v shell="false" \
        -v text_in_center="false" \
        -v waylandsessions="null" \
        -v xinitrc="null" \
        -v xsessions="/etc/ly/xsessions" \
        -v cmatrix_fg="$(ly_color 00 "$SECONDARY")" \
        -v cmatrix_head_col="$(ly_color 01 "$FG_STRONG")" \
        -v colormix_col1="$(ly_color 00 "$ACCENT")" \
        -v colormix_col2="$(ly_color 00 "$SECONDARY")" \
        -v colormix_col3="$(ly_color 00 "$SURFACE_3")" \
        -v doom_top_color="$(ly_color 00 "$ORANGE")" \
        -v doom_middle_color="$(ly_color 00 "$WARNING")" \
        -v doom_bottom_color="$(ly_color 00 "$FG_STRONG")" \
        -v gameoflife_fg="$(ly_color 00 "$SECONDARY")" '
            BEGIN {
                values["allow_empty_password"] = allow_empty_password
                values["animation"] = animation
                values["asterisk"] = asterisk
                values["bg"] = bg
                values["bigclock"] = bigclock
                values["blank_box"] = blank_box
                values["border_fg"] = border_fg
                values["box_title"] = box_title
                values["clear_password"] = clear_password
                values["clock"] = clock
                values["custom_sessions"] = custom_sessions
                values["default_input"] = default_input
                values["error_bg"] = error_bg
                values["error_fg"] = error_fg
                values["fg"] = fg
                values["hide_key_hints"] = hide_key_hints
                values["hide_keyboard_locks"] = hide_keyboard_locks
                values["hide_version_string"] = hide_version_string
                values["initial_info_text"] = initial_info_text
                values["input_len"] = input_len
                values["margin_box_h"] = margin_box_h
                values["margin_box_v"] = margin_box_v
                values["save"] = save
                values["session_log"] = session_log
                values["shell"] = shell
                values["text_in_center"] = text_in_center
                values["waylandsessions"] = waylandsessions
                values["xinitrc"] = xinitrc
                values["xsessions"] = xsessions
                values["cmatrix_fg"] = cmatrix_fg
                values["cmatrix_head_col"] = cmatrix_head_col
                values["colormix_col1"] = colormix_col1
                values["colormix_col2"] = colormix_col2
                values["colormix_col3"] = colormix_col3
                values["doom_top_color"] = doom_top_color
                values["doom_middle_color"] = doom_middle_color
                values["doom_bottom_color"] = doom_bottom_color
                values["gameoflife_fg"] = gameoflife_fg

                print "# Generated by CachyOS-Vault. Do not edit directly."
                print "# Source config: custom-configs/Ly/config.ini"
                print "# Source palette: custom-configs/Themes/color-palette/orchis-dark-palette.sh"
                print ""
            }
            {
                for (key in values) {
                    if ($0 ~ "^[[:space:]]*" key "[[:space:]]*=") {
                        print key " = " values[key]
                        next
                    }
                }
                print
            }
        ' "$SOURCE_CONFIG"
)

log_ok "Generated $OUTPUT_FILE"
